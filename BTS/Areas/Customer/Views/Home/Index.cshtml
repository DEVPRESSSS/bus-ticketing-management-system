@using BTS.Areas.Service.SD
@using BTS.Models.ViewModel
@model BookingVM
@{
    ViewData["Title"] = "Home Page";
}

@if (User.IsInRole(SdRoles.Customer))
{
    <div class="min-h-screen bg-gray-50 px-4 py-12">
        <div class="max-w-4xl mx-auto">

            <!-- Header -->
            <div class="text-center mb-10">
                <h1 class="text-4xl font-bold text-gray-900">Book Your <span class="text-teal-600">Bus Ticket</span></h1>
                <p class="text-gray-500 mt-2 text-sm">Select your travel date and choose an available bus.</p>
            </div>

            <!-- Search Card -->
            <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6 mb-8">
                <form method="get" asp-action="Search">
                    <div class="flex flex-col md:flex-row gap-4 items-end">

                        <!-- From -->
                        <div class="flex flex-col gap-1 flex-1">
                            <label class="text-sm font-medium text-gray-700">From</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </span>
                                <select asp-for="From"  asp-items="ViewBag.Routes"
                                        class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition">
                                    <option value=""> -- Select Origin --</option>
                                </select>
                                @* <input type="text" name="from" placeholder="Departure city"
                                       class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition" /> *@
                            </div>
                        </div>

                        <!-- Swap Icon -->
                        <div class="hidden md:flex items-center pb-1">
                            <div class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                                </svg>
                            </div>
                        </div>

                        <!-- To -->
                        <div class="flex flex-col gap-1 flex-1">
                            <label class="text-sm font-medium text-gray-700">To</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </span>
                                <select asp-for="To" asp-items="ViewBag.Routes"
                                        class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition">
                                    <option value="">-- Select Destination --</option>
                                </select>
                              @*   <input type="text" name="to" placeholder="Destination city"
                                       class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition" /> *@
                            </div>
                        </div>

                        <!-- Date -->
                        <div class="flex flex-col gap-1 flex-1">
                            <label class="text-sm font-medium text-gray-700">Travel Date</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </span>
                                <input type="date" asp-for="SelectedDate" 
                                       class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition" />
                            </div>
                        </div>

                        <!-- Search Button -->
                        <div class="w-full md:w-auto">
                            <button type="submit"
                                    class="w-full md:w-auto bg-teal-600 hover:bg-violet-700 text-white text-sm font-medium px-6 py-3 rounded-xl transition-colors duration-200">
                                Search Buses
                            </button>
                        </div>

                    </div>
                </form>
            </div>

            <!-- Results Section -->
            <div>
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Available Buses</h2>

                <div class="flex flex-col gap-4">
                    @foreach (var item in Model.Schedules)
                    {
                      
                           
                    <!-- Bus Card (repeat this per result) -->
                    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6 hover:border-violet-300 transition-all duration-200 cursor-pointer">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">

                        

                                <!-- Bus Info -->
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-xl bg-teal-50 flex items-center justify-center flex-shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v9a2 2 0 01-2 2h-3m-8 0h8m-8 0a2 2 0 100 4 2 2 0 000-4zm8 0a2 2 0 100 4 2 2 0 000-4z" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-gray-900">@item.Buses?.BusName</p>
                                        <p class="text-xs text-gray-400 mt-0.5">
                                            @(item.Route?.OriginStation?.StationName + " → " + item.Route?.DestinationStation?.StationName + " - " + item.Buses?.BusType?.BusTypeName)
                                        </p>
                                    </div>
                                </div>

                                <!-- Time -->
                                <div class="flex items-center gap-6 text-center">
                                    <div>
                                        <p class="text-sm font-bold text-gray-900">@item.DepartureTime.ToString("MM d, yyyy hh:mm tt")</p>
                                        <p class="text-xs text-gray-400">Departure</p>
                                    </div>
                                    <div class="flex flex-col items-center">
                                        <p class="text-xs text-gray-400">
                                            @((item.ArrivalTime - item.DepartureTime).ToString(@"hh\:mm"))

                                        </p>
                                        <div class="w-16 h-px bg-gray-200 my-1"></div>
                                        <p class="text-xs text-teal-500">Direct</p>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-gray-900">@item.ArrivalTime.ToString("MM d, yyyy hh:mm tt")</p>
                                        <p class="text-xs text-gray-400">Arrival</p>
                                    </div>
                                </div>

                                <!-- Seats & Price -->
                                <div class="flex flex-col items-end gap-2">
                                    <span class="text-xs font-medium text-green-600 bg-green-50 px-2 py-0.5 rounded-full">
                                        @item.AvailableSeats seats left
                                    </span>
                                    <p class="text-xl font-bold text-teal-600">@item.Route?.BasePrice.ToString()</p>
                                    <a onclick="showModal('@item.ScheduleId')"
                                           class="bg-teal-600 hover:bg-teal-700 text-white text-xs font-medium p-2 rounded-xl transition-colors duration-200">
                                        Book Now
                                    </a>
                                </div>
                
                            </div>
                                                    
                     
                         </div>
                  

                    }

                    <!-- No Results State -->
                    @*
                    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-12 text-center">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-12 h-12 text-gray-200 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                        <p class="text-gray-400 text-sm">No buses available for the selected date and route.</p>
                    </div>
                    *@

                </div>
            </div>

        </div>
    </div>
}

<!-- Seat Booking Modal -->
<div id="seatModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
    <div class="bg-white rounded-2xl shadow-lg p-6 w-full max-w-sm mx-4">
        <div class="flex items-center justify-between mb-4">
            <h2 class="text-base font-semibold text-gray-900">Select Number of Seats</h2>
            <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
            </button>
        </div>

        <div class="flex flex-col gap-2 mb-6">
            <label class="text-sm font-medium text-gray-700">Number of Seats</label>
            <input type="number" id="seatCount" min="1" max="10" value="1"
                   class="w-full px-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900
            focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition" />
            <p class="text-xs text-gray-400">Enter a value between 1 and 10.</p>
        </div>

        <div class="flex gap-3">
            <button onclick="closeModal()"
                    class="flex-1 py-2.5 rounded-xl border border-gray-200 text-sm text-gray-600 hover:bg-gray-50 transition">
                Cancel
            </button>
            <!-- Hidden form inside the modal, above the Confirm button -->
            <form id="bookingForm" method="post" asp-action="ConfirmBooking">
                @Html.AntiForgeryToken()
                <input type="hidden" id="hiddenScheduleId" name="ScheduleId" />
                <input type="hidden" id="hiddenSeats" name="SeatCount" />
            </form>
            <button onclick="confirmBooking()"
                    class="flex-1 py-2.5 rounded-xl bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium transition">
                Confirm
            </button>
        </div>
    </div>
</div>
@section Scripts {
    <script>
        let selectedScheduleId = null;

        function showModal(scheduleId) {
            selectedScheduleId = scheduleId;
            document.getElementById('seatCount').value = 1;
            const modal = document.getElementById('seatModal');
            modal.classList.remove('hidden');
            modal.classList.add('flex');
        }

        function closeModal() {
            const modal = document.getElementById('seatModal');
            modal.classList.add('hidden');
            modal.classList.remove('flex');
        }

        function confirmBooking() {
            const seats = parseInt(document.getElementById('seatCount').value);
            if (isNaN(seats) || seats < 1) {
                alert('Please enter a valid number of seats.');
                return;
            }
             document.getElementById('hiddenScheduleId').value = selectedScheduleId;
             document.getElementById('hiddenSeats').value = seats;
             document.getElementById('bookingForm').submit();
        }

        document.getElementById('seatModal').addEventListener('click', function (e) {
            if (e.target === this) closeModal();
        });
    </script>
}