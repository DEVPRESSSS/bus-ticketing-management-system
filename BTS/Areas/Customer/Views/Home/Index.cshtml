@using BTS.Areas.Service.SD
@using BTS.Models.ViewModel
@using Microsoft.AspNetCore.Identity
@model BookingVM
@{
    ViewData["Title"] = "Home Page";
}
@inject UserManager<ApplicationUser> UserManager

@if (User.IsInRole(SdRoles.Customer))
{
    <div class="min-h-screen bg-gray-50 px-4 py-12">
        <div class="max-w-4xl mx-auto">

            <!-- Header -->
            <div class="text-center mb-10">
                <h1 class="text-4xl font-bold text-gray-900">Book Your <span class="text-teal-600">Bus Ticket</span></h1>
                <p class="text-gray-500 mt-2 text-sm">Select your travel date and choose an available bus.</p>
            </div>

            <!-- Search Card -->
            <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6 mb-8">
                <form method="get" asp-action="Search">
                    <div class="flex flex-col md:flex-row gap-4 items-end">

                        <!-- From -->
                        <div class="flex flex-col gap-1 flex-1">
                            <label class="text-sm font-medium text-gray-700">Choose bus route</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </span>
                                <select asp-for="From"  asp-items="ViewBag.Routes"
                                        class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition">
                                    <option value=""> -- Select origin and destination  --</option>
                                </select>
                                @* <input type="text" name="from" placeholder="Departure city"
                                       class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition" /> *@
                            </div>
                        </div>

                        <!-- Swap Icon -->
                        <div class="hidden md:flex items-center pb-1">
                            <div class="w-8 h-8 rounded-full bg-teal-50 flex items-center justify-center">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                                </svg>
                            </div>
                        </div>

                        <!-- To 
                        <div class="flex flex-col gap-1 flex-1">
                            <label class="text-sm font-medium text-gray-700">To</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
                                    </svg>
                                </span>
                                <select asp-for="To" asp-items="ViewBag.Routes"
                                        class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition">
                                    <option value="">-- Select Destination --</option>
                                </select>
                              @*   <input type="text" name="to" placeholder="Destination city"
                                       class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition" /> *@
                            </div>
                        </div>
                        -->
                        <!-- Date -->
                        <div class="flex flex-col gap-1 flex-1">
                            <label class="text-sm font-medium text-gray-700">Travel Date</label>
                            <div class="relative">
                                <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">
                                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                                    </svg>
                                </span>
                                <input type="date" asp-for="SelectedDate" min="@DateTime.Now.ToString("yyyy-MM-dd")" 
                                       max="@($"{new DateTime(DateTime.Now.Year, 12, 31):yyyy-MM-dd}")" class="w-full pl-9 pr-4 py-3 rounded-xl border border-gray-200 text-sm text-gray-900 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition" />
                            </div>
                        </div>

                        <!-- Search Button -->
                        <div class="w-full md:w-auto">
                            <button type="submit"
                                    class="w-full md:w-auto bg-teal-600 hover:bg-violet-700 text-white text-sm font-medium px-6 py-3 rounded-xl transition-colors duration-200">
                                Search Buses
                            </button>
                        </div>

                    </div>
                </form>
            </div>

            <!-- Results Section -->
            <div>
                <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">@(Model.Schedules.Any() ? "Available buse" : "Sorry no bus schedule available")</h2>

                <div class="flex flex-col gap-4">
                    @foreach (var item in Model.Schedules)
                    {
                      
                           
                    <!-- Bus Card (repeat this per result) -->
                    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-6 hover:border-violet-300 transition-all duration-200 cursor-pointer">
                        <div class="flex flex-col md:flex-row md:items-center justify-between gap-4">

                        

                                <!-- Bus Info -->
                                <div class="flex items-center gap-4">
                                    <div class="w-12 h-12 rounded-xl bg-teal-50 flex items-center justify-center flex-shrink-0">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-teal-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v9a2 2 0 01-2 2h-3m-8 0h8m-8 0a2 2 0 100 4 2 2 0 000-4zm8 0a2 2 0 100 4 2 2 0 000-4z" />
                                        </svg>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-gray-900">@item.Buses?.BusName</p>
                                        <p class="text-xs text-gray-400 mt-0.5">
                                            @(item.Route?.OriginStation?.StationName + " → " + item.Route?.DestinationStation?.StationName + " - " + item.Buses?.BusType?.BusTypeName)
                                        </p>
                                    </div>
                                </div>

                                <!-- Time -->
                                <div class="flex items-center gap-6 text-center">
                                    <div>
                                        <p class="text-sm font-bold text-gray-900">@item.DepartureTime.ToString("dddd d, yyyy hh:mm tt")</p>
                                        <p class="text-xs text-gray-400">Departure</p>
                                    </div>
                                    <div class="flex flex-col items-center">
                                        <p class="text-xs text-gray-400">
                                            @((item.ArrivalTime - item.DepartureTime).ToString(@"hh\:mm"))

                                        </p>
                                        <div class="w-16 h-px bg-gray-200 my-1"></div>
                                        <p class="text-xs text-teal-500">Direct</p>
                                    </div>
                                    <div>
                                        <p class="text-sm font-bold text-gray-900">@item.ArrivalTime.ToString("dddd d, yyyy hh:mm tt")</p>
                                        <p class="text-xs text-gray-400">Arrival</p>
                                    </div>
                                </div>

                                <!-- Seats & Price -->
                                <div class="flex flex-col items-end gap-2">
                                    <span class="text-xs font-medium @(item.AvailableSeats >= 1 ? "text-green-600 bg-green-50" : "text-red-600 bg-red-50")   px-2 py-0.5 rounded-full" )>
                                        @(item.AvailableSeats >= 1 ? $"{item.AvailableSeats + " seats left"}" : "Fully booked")
                                    </span>
                                    <p class="text-xl font-bold text-teal-600">@item.Route?.BasePrice.ToString()</p>
                                    <a onclick="showModal('@item.ScheduleId')"
                                           class="bg-teal-600 hover:bg-teal-700 text-white text-xs font-medium p-2 rounded-xl transition-colors duration-200 @(item.AvailableSeats  == 0 ? "hidden" : "visible" )">
                                        Book Now
                                    </a>
                                </div>
                
                            </div>
                                                    
                     
                         </div>
                  

                    }

                

                </div>
            </div>

        </div>
    </div>

    <!-- Seat Booking Modal -->
    <div id="seatModal" class="fixed inset-0 z-50 hidden items-center justify-center bg-black/40">
        <div class="bg-white rounded-2xl shadow-lg p-5 w-full max-w-sm mx-4">
            <div class="flex items-center justify-between mb-3">
                <h2 class="text-base font-semibold text-gray-900">Book Your Seat</h2>
                <button onclick="closeModal()" class="text-gray-400 hover:text-gray-600 transition">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

         
            <!-- Seat Count -->
            <div class="flex flex-col gap-1 mb-4">
                <label class="text-sm font-medium text-gray-700">Number of Seats</label>
                <input type="number" id="seatCount" min="1" max="10" value="1"
                       class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm text-gray-900
                focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition" />
                <p class="text-xs text-gray-400">Enter a value between 1 and 10.</p>
            </div>

            <!-- GCash Payment Section -->
            <div class="border-t border-gray-100 pt-4 mb-4">
                <p class="text-sm font-medium text-gray-700 mb-2">Payment via GCash</p>

                <!-- QR Code -->
                <div class="flex justify-center mb-2">
                    <div class="border border-gray-200 rounded-xl p-2 inline-block">
                        <img src="~/Images/Maya.jpg" alt="GCash QR Code"
                             class="w-48 h-48 object-contain" />
                    </div>
                </div>
                <p class="text-xs text-center text-gray-400 mb-3">
                    Scan to pay via GCash &middot;
                    <span class="text-gray-600 font-medium">Juan Dela Cruz</span>
                </p>

                <!-- Reference Number -->
                <div class="flex flex-col gap-1">
                    <label asp-for="ReferenceNumber" class="text-sm font-medium text-gray-700">
                        GCash Reference Number
                    </label>
                    <input type="text" asp-for="ReferenceNumber" id="gcashRef" 
                           placeholder="e.g. 1234567890"
                           maxlength="13"
                           class="w-full px-3 py-2 rounded-xl border border-gray-200 text-sm text-gray-900
                    focus:outline-none focus:ring-2 focus:ring-teal-500 focus:border-transparent transition" required />
                    <p class="text-xs text-gray-400">Enter the 13-digit reference number from your GCash receipt.</p>
                </div>
            </div>

            <!-- Actions -->
            <div class="flex gap-3">
                <button onclick="closeModal()"
                        class="flex-1 py-2 rounded-xl border border-gray-200 text-sm text-gray-600 hover:bg-gray-50 transition">
                    Cancel
                </button>
                <form id="bookingForm" method="post" asp-action="ConfirmBooking">
                    @Html.AntiForgeryToken()
                    <input type="hidden" id="hiddenScheduleId" name="ScheduleId" />
                    <input type="hidden" id="hiddenSeats" name="SeatCount" />
                    <input type="hidden" id="hiddenGcashRef" name="ReferenceNumber" />
          
                </form>
                <button onclick="confirmBooking()"
                        class="flex-1 py-2 rounded-xl bg-teal-600 hover:bg-teal-700 text-white text-sm font-medium transition">
                    Confirm
                </button>
            </div>
        </div>
    </div>
}
else
{

    @if (!User.IsInRole(SdRoles.Admin))
    {
        <div class="min-h-screen bg-white">

            <!-- Hero Section -->
            <div class="bg-teal-600 relative overflow-hidden">
                <div class="absolute inset-0 opacity-10"
                style="background-image: repeating-linear-gradient(45deg, #000 0, #000 1px, transparent 0, transparent 50%); background-size: 20px 20px;">
                </div>
                <div class="relative z-10 max-w-5xl mx-auto px-6 py-24 text-center">
                    <div class="inline-flex items-center gap-2 bg-white/10 text-white text-xs font-medium px-3 py-1.5 rounded-full mb-6">
                        <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" />
                        </svg>
                        Bus Ticketing System
                    </div>
                    <h1 class="text-4xl md:text-5xl font-extrabold text-white leading-tight mb-4">
                        Travel Smarter,<br />Book Faster.
                    </h1>
                    <p class="text-teal-100 text-sm md:text-base max-w-xl mx-auto mb-8">
                        Book bus tickets online, track your rides, and manage your trips — all in one place. Fast, easy, and reliable.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-3 justify-center">
                        <a asp-area="Identity" asp-page="/Account/Register"
                        class="bg-white text-teal-600 font-bold text-sm px-6 py-3 rounded-xl hover:bg-teal-50 transition-colors duration-200">
                            Get Started
                        </a>
                        <a asp-area="Identity" asp-page="/Account/Login"
                        class="border border-white/40 text-white font-medium text-sm px-6 py-3 rounded-xl hover:bg-white/10 transition-colors duration-200">
                            Sign In
                        </a>
                    </div>
                </div>
            </div>

            <!-- Features Section -->
            <div class="max-w-5xl mx-auto px-6 py-20">
                <div class="text-center mb-12">
                    <h2 class="text-2xl font-bold text-gray-900">Everything you need to travel</h2>
                    <p class="text-gray-500 text-sm mt-2">Simple tools to make your journey hassle-free.</p>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">

                    <!-- Feature 1 -->
                    <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center">
                        <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center mx-auto mb-4">
                            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </div>
                        <h3 class="text-sm font-bold text-gray-900 mb-1">Search Routes</h3>
                        <p class="text-xs text-gray-500 leading-relaxed">Find available buses between your origin and destination in seconds.</p>
                    </div>

                    <!-- Feature 2 -->
                    <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center">
                        <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center mx-auto mb-4">
                            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                            </svg>
                        </div>
                        <h3 class="text-sm font-bold text-gray-900 mb-1">Book Tickets</h3>
                        <p class="text-xs text-gray-500 leading-relaxed">Reserve your seat instantly with just a few clicks — no queues needed.</p>
                    </div>

                    <!-- Feature 3 -->
                    <div class="bg-gray-50 border border-gray-100 rounded-2xl p-6 text-center">
                        <div class="w-12 h-12 bg-teal-100 rounded-xl flex items-center justify-center mx-auto mb-4">
                            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2" />
                            </svg>
                        </div>
                        <h3 class="text-sm font-bold text-gray-900 mb-1">Manage Trips</h3>
                        <p class="text-xs text-gray-500 leading-relaxed">View and track all your bookings from your personal dashboard.</p>
                    </div>

                </div>
            </div>

            <!-- CTA Section -->
            <div class="bg-gray-50 border-t border-gray-100">
                <div class="max-w-3xl mx-auto px-6 py-16 text-center">
                    <h2 class="text-2xl font-bold text-gray-900 mb-2">Ready to book your trip?</h2>
                    <p class="text-gray-500 text-sm mb-6">Create a free account and start booking in minutes.</p>
                    <a asp-area="Identity" asp-page="/Account/Register"
                    class="inline-block bg-teal-600 hover:bg-teal-700 text-white font-bold text-sm px-8 py-3 rounded-xl transition-colors duration-200">
                        Create Free Account
                    </a>
                </div>
            </div>

        </div>
    }
    else
    {
        <div class="min-h-screen bg-gray-50 px-4 py-12">
            <div class="max-w-5xl mx-auto">

                <!-- Welcome Header -->
                <div class="mb-10">
                    <h1 class="text-3xl font-bold text-gray-900">Welcome back, <span class="text-teal-600">Admin @UserManager.GetUserName(User)! </span></h1>
                    <p class="text-gray-500 text-sm mt-1">Here's a quick overview of your system.</p>
                </div>

                <!-- Stats Cards -->
                <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4 mb-10">

                    <!-- Buses -->
                    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5 flex items-center gap-4">
                        <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v9a2 2 0 01-2 2h-3m-8 0h8m-8 0a2 2 0 100 4 2 2 0 000-4zm8 0a2 2 0 100 4 2 2 0 000-4z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 font-medium">Total Buses</p>
                            <p class="text-xl font-bold text-gray-900">@(ViewBag.BusesCount ?? 0)</p>
                        </div>
                    </div>

                    <!-- Schedules -->
                    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5 flex items-center gap-4">
                        <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 font-medium">Schedules</p>
                            <p class="text-xl font-bold text-gray-900">@(ViewBag.ScheduleCount ?? 0)</p>
                        </div>
                    </div>

                    <!-- Bookings -->
                    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5 flex items-center gap-4">
                        <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 font-medium">Total Bookings</p>
                            <p class="text-xl font-bold text-gray-900">@(ViewBag.TicketCount ?? 0)</p>
                        </div>
                    </div>

                    <!-- Users -->
                    <div class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5 flex items-center gap-4">
                        <div class="w-12 h-12 bg-teal-50 rounded-xl flex items-center justify-center flex-shrink-0">
                            <svg class="w-6 h-6 text-teal-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <div>
                            <p class="text-xs text-gray-400 font-medium">Registered Users</p>
                            <p class="text-xl font-bold text-gray-900">@(ViewBag.UsersCount ?? 0)</p>
                        </div>
                    </div>

                </div>

                <!-- Quick Actions -->
                <div class="mb-10">
                    <h2 class="text-sm font-semibold text-gray-400 uppercase tracking-wider mb-4">Quick Actions</h2>
                    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">

                        <a asp-area="Admin" asp-controller="Bus" asp-action="Index"
                               class="bg-white border border-gray-100 rounded-2xl shadow-sm p-5 flex items-center gap-4 hover:border-teal-300 transition-all duration-200 group">
                            <div class="w-10 h-10 bg-teal-50 rounded-xl flex items-center justify-center group-hover:bg-teal-100 transition">
                                <svg class="w-5 h-5 text-teal-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 17H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v9a2 2 0 01-2 2h-3m-8 0h8m-8 0a2 2 0 100 4 2 2 0 000-4zm8 0a2 2 0 100 4 2 2 0 000-4z" />
                                </svg>
                            </div>
                            <div>
                                <p class="text-sm font-semibold text-gray-900">Manage Buses</p>
                                <p class="text-xs text-gray-400">Add, edit, or remove buses</p>
                            </div>
                        </a>

                        <a asp-area="Admin" asp-controller="Schedule" asp-action="Index"
