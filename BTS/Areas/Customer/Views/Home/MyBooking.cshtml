@model List<Tickets>
@foreach(var item in Model)
{
<div class="flex md:flex-row justify-center w-full shadow-sm bg-white rounded-2xl overflow-hidden border border-gray-100">

    <!-- Bus Information -->
    <div class="flex-1 px-6 py-5 border-r-2 border-dashed border-gray-200 relative">

        <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-teal-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M8 17H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v9a2 2 0 01-2 2h-3m-8 0h8m-8 0a2 2 0 100 4 2 2 0 000-4zm8 0a2 2 0 100 4 2 2 0 000-4z" />
                </svg>
            </div>
            <span class="text-xs font-medium text-gray-400 uppercase tracking-widest">Bus information</span>
        </div>

        <p class="text-base font-semibold text-gray-900">@item.Schedules?.Buses?.BusName</p>
            <p class="text-xs text-gray-400 mb-4">@item.Schedules?.Buses?.BusType?.BusTypeName</p>

        <!-- Route row -->
        <div class="flex items-center gap-3 mb-4">
            <div class="text-center">
                <p class="text-sm font-semibold text-gray-900">@item.Schedules?.Route?.OriginStation?.StationName</p>
                <p class="text-xs text-gray-400">@item.Schedules?.DepartureTime.ToString("hh:mm tt")</p>
            </div>
            <div class="flex-1 flex flex-col items-center gap-0.5">
                <p class="text-xs text-gray-400">
                    @((item.Schedules?.ArrivalTime - item.Schedules?.DepartureTime)?.ToString(@"hh\:mm"))
                </p>
                <div class="w-full flex items-center gap-1">
                    <div class="w-2 h-2 rounded-full border-2 border-teal-500"></div>
                    <div class="flex-1 h-px bg-teal-500"></div>
                    <div class="w-2 h-2 rounded-full bg-teal-500"></div>
                </div>
                <p class="text-xs text-teal-600">Direct</p>
            </div>
            <div class="text-center">
                <p class="text-sm font-semibold text-gray-900">@item.Schedules?.Route?.DestinationStation?.StationName</p>
                <p class="text-xs text-gray-400">@item.Schedules?.ArrivalTime.ToString("hh:mm tt")</p>
            </div>
        </div>

        <p class="text-xs text-gray-400">@item.Schedules?.DepartureTime.ToString("MMM dd, yyyy · dddd")</p>

        <!-- Notch cutouts -->
        <div class="absolute -right-2 -top-2 w-4 h-4 rounded-full bg-gray-50"></div>
        <div class="absolute -right-2 -bottom-2 w-4 h-4 rounded-full bg-gray-50"></div>
    </div>

    <!-- Ticket Information -->
    <div class="flex-1 px-6 py-5">

        <div class="flex items-center gap-2 mb-4">
            <div class="w-8 h-8 rounded-lg bg-teal-50 flex items-center justify-center">
                <svg class="w-4 h-4 text-teal-700" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 5v2m0 4v2m0 4v2M5 5a2 2 0 00-2 2v3a2 2 0 110 4v3a2 2 0 002 2h14a2 2 0 002-2v-3a2 2 0 110-4V7a2 2 0 00-2-2H5z" />
                </svg>
            </div>
            <span class="text-xs font-medium text-gray-400 uppercase tracking-widest">Ticket information</span>
        </div>

        <div class="flex flex-col gap-3">
            <div class="flex justify-between items-center">
                <span class="text-xs text-gray-400">Ticket code</span>
                <span class="text-xs font-medium text-gray-900 font-mono">@item.TicketCode</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-xs text-gray-400">Seat</span>
                <span class="text-sm font-semibold text-gray-900">@item.Seats?.SeatNumber</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-xs text-gray-400">Passenger</span>
                <span class="text-sm font-semibold text-gray-900">@item.ApplicationUser?.FullName</span>
            </div>
            <div class="flex justify-between items-center">
                <span class="text-xs text-gray-400">Status</span>
                <span class="text-xs font-medium text-teal-800 bg-teal-50 px-3 py-0.5 rounded-full">@item.Status</span>
            </div>
            <div class="border-t border-gray-100 pt-3 flex justify-between items-center">
                <span class="text-xs text-gray-400">Amount to be paid</span>
                <span class="text-lg font-bold text-teal-600">₱@item.AmountPaid.ToString("N2")</span>
            </div>
        </div>

    </div>
</div>
}