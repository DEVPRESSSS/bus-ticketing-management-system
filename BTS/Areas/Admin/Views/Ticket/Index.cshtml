@model List<Tickets>

<div class="shadow-sm w-full p-2 rounded-lg mt-4">

    <!--Header-->
    <div class="p-2 flex flex-col sm:flex-row">
        <div class="flex flex-1 content-center">
            <h3 class="text-teal-600 font-mona font-bold p-2">Tickets List</h3>
        </div>
    </div>

    <!--Divider-->
    <div class="border-b border-gray-200 w-full"></div>

    <!--Table-->
    <div class="w-full overflow-x-auto rounded-lg border border-gray-200">
        <table class="w-full text-sm font-mona">
            <!--Head-->
            <thead class="bg-teal-600 text-white">
                <tr>
                    <th class="text-left px-4 py-3 font-semibold">Ticket Code</th>
                    <th class="text-left px-4 py-3 font-semibold">Passenger</th>
                    <th class="text-left px-4 py-3 font-semibold">Seat</th>
                    <th class="text-left px-4 py-3 font-semibold">Bus</th>
                    <th class="text-left px-4 py-3 font-semibold">Schedule</th>
                    <th class="text-left px-4 py-3 font-semibold">Fare</th>
                    <th class="text-left px-4 py-3 font-semibold">Payment</th>
                    <th class="text-left px-4 py-3 font-semibold">PaymentStatus</th>
                    <th class="text-left px-4 py-3 font-semibold">Booked At</th>
                    <th class="text-left px-4 py-3 font-semibold">Status</th>
                    <th class="text-left px-4 py-3 font-semibold">Actions</th>
                </tr>
            </thead>
            <!--Body-->
            <tbody class="divide-y divide-gray-100">
                @foreach (var ticket in Model)
                {
                    <tr class="hover:bg-teal-50 transition-colors">
                        <td class="px-4 py-3 text-gray-500 font-mono text-xs">@ticket.TicketCode</td>
                        <td class="px-4 py-3 text-gray-800 font-medium">@ticket.ApplicationUser?.FullName</td>
                        <td class="px-4 py-3 text-gray-500">@ticket.Seats?.SeatNumber</td>
                        <th class="text-left px-4 py-3 font-semibold">@($"{ticket.Schedules?.Buses?.BusName + " - " + ticket.Schedules?.Buses.BusNumber}") </th>
                        <td class="px-4 py-3 text-gray-500 text-xs">
                            @ticket.Schedules?.DepartureTime.ToString("MMM d, yyyy hh:mm tt")
                        </td>
                        <td class="px-4 py-3 text-gray-800 font-semibold">₱@ticket.AmountPaid.ToString("N2")</td>
                        <td class="px-4 py-3 text-gray-800 font-semibold">@ticket.ReferenceNumber</td>
                        <td class="px-4 py-3">
                            <span class="px-2 py-0.5 rounded-full text-xs font-semibold
                                @(ticket.PaymentStatus == "Paid" ? "bg-green-50 text-green-600 border border-green-200" :
                                            ticket.PaymentStatus == "Pending" ? "bg-yellow-50 text-yellow-600 border border-yellow-200" :
                                            "bg-red-50 text-red-600 border border-red-200")">
                                @ticket.PaymentStatus
                            </span>
                        </td>
                        <td class="px-4 py-3 text-gray-400 text-xs">
                            @ticket.BookedAt?.ToString("MMM d, yyyy hh:mm tt")
                        </td>
                        <td class="px-4 py-3">
                            @{
                                var statusClass = ticket.Status switch
                                {
                                    "Approved" => "bg-green-50 text-green-600 border border-green-200",
                                    "Rejected" => "bg-red-50 text-red-500 border border-red-200",
                                    "Cancelled" => "bg-gray-100 text-gray-400 border border-gray-200",
                                    _ => "bg-yellow-50 text-yellow-600 border border-yellow-200"
                                };
                            }
                            <span class="px-2 py-0.5 rounded-full text-xs font-semibold @statusClass">
                                @(ticket.Status ?? "Pending")
                            </span>
                        </td>
                        <td class="px-4 py-3">
                            <div class="flex gap-2 flex-wrap">
                                @if (ticket.Status != "Approved" && ticket.Status != "Rejected" && ticket.Status != "Cancelled")
                                {
                                        <a asp-action="Approve" asp-route-ticketId="@ticket.TicketId"
                                               class="text-green-600 border border-green-500 px-3 py-1 rounded-lg text-xs font-semibold hover:bg-green-500 hover:text-white transition-colors">
                                            Approve
                                        </a>
                                        <a asp-action="Reject" asp-route-ticketId="@ticket.TicketId"
                                               class="text-red-500 border border-red-400 px-3 py-1 rounded-lg text-xs font-semibold hover:bg-red-500 hover:text-white transition-colors">
                                            Reject
                                        </a>
                                
                                }
                                else
                                {
                                    <span class="text-gray-300 text-xs italic">No actions</span>
                                }
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>

        <!--Pagination-->
        <div class="flex items-center justify-between px-4 py-3 border-t border-gray-200">
            <p class="text-xs text-gray-500 font-mona">
                Page @ViewBag.CurrentPage of @ViewBag.TotalPages
            </p>
            <div class="flex gap-1">
                @if (ViewBag.CurrentPage > 1)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage - 1)"
                           class="px-3 py-1 text-xs font-mona font-semibold border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">
                        &larr; Prev
                    </a>
                }

                @for (int i = 1; i <= ViewBag.TotalPages; i++)
                {
                    <a asp-action="Index" asp-route-page="@i"
                           class="px-3 py-1 text-xs font-mona font-semibold border rounded-lg transition-colors
                        @(i == ViewBag.CurrentPage
                                                   ? "bg-teal-600 text-white border-teal-600"
                                                   : "border-gray-200 text-gray-600 hover:bg-gray-50")">
                        @i
                    </a>
                }

                @if (ViewBag.CurrentPage < ViewBag.TotalPages)
                {
                    <a asp-action="Index" asp-route-page="@(ViewBag.CurrentPage + 1)"
                           class="px-3 py-1 text-xs font-mona font-semibold border border-gray-200 rounded-lg text-gray-600 hover:bg-gray-50 transition-colors">
                        Next &rarr;
                    </a>
                }
            </div>
        </div>
    </div>

</div>